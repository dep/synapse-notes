# Copy to .env.local and fill in your GitHub OAuth app credentials.
# Create one at https://github.com/settings/developers
#   Homepage URL:        http://localhost:5174
#   Authorization URL:   http://localhost:5174/api/oauth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
VITE_GITHUB_CLIENT_ID=

# Optional. When deployed set this to your public origin (no trailing slash).
# PUBLIC_APP_ORIGIN=https://your-host.example.com
# VITE_PUBLIC_APP_ORIGIN=https://your-host.example.com
